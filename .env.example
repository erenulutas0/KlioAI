# Local-only environment variables for docker compose bring-up.
# Create a .env file next to docker-compose.yml and fill values as needed.

# Backend (required for login/token issuance)
APP_SECURITY_JWT_SECRET=

# Optional: used by backend if you want AI calls locally
GROQ_API_KEY=

# Optional: override default postgres credentials/port mapping
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

