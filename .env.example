# Environment variables for docker compose bring-up and preflight checks.
# Create a .env file next to docker-compose.yml and fill values as needed.
# Never commit real secrets.

# Backend (required for login/token issuance)
APP_SECURITY_JWT_SECRET=
APP_SECURITY_JWT_ENFORCE_AUTH=true

# Keep mock verification disabled for prod-like runtime checks
APP_SUBSCRIPTION_MOCK_VERIFICATION_ENABLED=false

# Required for AI-backed features (and prod-preflight)
GROQ_API_KEY=

# Optional: override AI plan policy defaults
APP_SECURITY_AI_TOKEN_QUOTA_TRIAL_DURATION_DAYS=7
APP_SECURITY_AI_TOKEN_QUOTA_TRIAL_DAILY_TOKEN_QUOTA_PER_USER=25000
APP_SECURITY_AI_TOKEN_QUOTA_FREE_DAILY_TOKEN_QUOTA_PER_USER=0
APP_SECURITY_AI_TOKEN_QUOTA_PREMIUM_DAILY_TOKEN_QUOTA_PER_USER=50000
APP_SECURITY_AI_TOKEN_QUOTA_PREMIUM_PLUS_DAILY_TOKEN_QUOTA_PER_USER=100000

# Optional: model routing
APP_AI_MODEL_ROUTING_ENABLED=true
APP_AI_MODEL_ROUTING_SPEECH_MODEL=llama-3.3-70b-versatile
APP_AI_MODEL_ROUTING_UTILITY_MODEL=openai/gpt-oss-20b

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# Redis security
SPRING_DATA_REDIS_PASSWORD=
SPRING_DATA_REDIS_SECURITY_PASSWORD=

# CORS (comma-separated)
APP_CORS_ALLOWED_ORIGINS=

# Google auth (comma-separated OAuth client IDs accepted by backend)
APP_SECURITY_AUTH_GOOGLE_CLIENT_IDS=

# Payments
# Play Store subscriptions are verified server-side via Google Play Billing config below.

# Google Play Billing verification (server-side)
APP_SUBSCRIPTION_GOOGLE_PLAY_ENABLED=true
APP_SUBSCRIPTION_GOOGLE_PLAY_PACKAGE_NAME=
# Host path to Google service-account JSON; mounted in prod as:
# /run/secrets/google-play-service-account.json
APP_SUBSCRIPTION_GOOGLE_PLAY_SERVICE_ACCOUNT_HOST_PATH=
APP_SUBSCRIPTION_GOOGLE_PLAY_PRODUCT_PLAN_PRO_MONTHLY=PREMIUM
APP_SUBSCRIPTION_GOOGLE_PLAY_PRODUCT_PLAN_PRO_ANNUAL=PREMIUM_PLUS
APP_SUBSCRIPTION_GOOGLE_PLAY_PRODUCT_PLAN_PREMIUM_MONTHLY=PREMIUM
APP_SUBSCRIPTION_GOOGLE_PLAY_PRODUCT_PLAN_PREMIUM_PLUS_MONTHLY=PREMIUM_PLUS
APP_SUBSCRIPTION_GOOGLE_PLAY_PRODUCT_PLAN_MONTHLY=PREMIUM
APP_SUBSCRIPTION_GOOGLE_PLAY_RECONCILIATION_ENABLED=true
APP_SUBSCRIPTION_GOOGLE_PLAY_RECONCILIATION_CRON=0 */30 * * * *
APP_SUBSCRIPTION_GOOGLE_PLAY_RECONCILIATION_MAX_USERS_PER_RUN=200

# Alert routing webhooks
ALERTMANAGER_DEFAULT_WEBHOOK_URL=
ALERTMANAGER_CRITICAL_WEBHOOK_URL=
ALERTMANAGER_WARNING_WEBHOOK_URL=
